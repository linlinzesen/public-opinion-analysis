# ============================================================
# .gitignore —— 请勿上传以下类型的文件！
# 老师要求：禁止上传安装包依赖、二进制文件、运行时产物
# ============================================================

# ── Python 运行时产物 ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
*.egg-info
dist/
build/
eggs/
*.whl

# ── Python 虚拟环境（安装包依赖）──
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.env

# ── Node.js 依赖与构建产物 ──
node_modules/
.npm-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
dist-ssr/

# ── IDE 与编辑器配置 ──
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── 操作系统临时文件 ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Office 临时文件（Word/Excel 锁定文件）──
~$*.docx
~$*.xlsx
~$*.pptx
~$*.doc
~$*.xls
~$*.ppt
*.tmp

# ── 数据与日志（按需取消注释）──
*.log
*.out

# ── 敏感配置文件 ──
*.pem
*.key
secrets/
credentials/

# ── 其他 ──
*.zip
*.tar.gz
*.rar
*.7z
